{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Dev Server",
      "type": "npm",
      "script": "dev",
      "path": "viewer",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:\\s+http"
        }
      }
    },
    {
      "label": "Copy Specs to Viewer",
      "type": "npm",
      "script": "copy-spec",
      "path": "viewer"
    }
  ]
}
