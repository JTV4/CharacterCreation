{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Viewer (Dev Server)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/viewer",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Launch Viewer (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/viewer/src",
      "preLaunchTask": "Start Dev Server"
    }
  ]
}
